{
    "version": 2,
    "buildCommand": "echo 'Static site'",
    "installCommand": "echo 'No dependencies to install'",
    "framework": null,
    "public": true,
    "cleanUrls": true,
    "headers": [{
            "source": "/(.*)",
            "headers": [{
                "key": "X-Content-Type-Options",
                "value": "nosniff"
            }]
        },
        {
            "source": "/styles.css",
            "headers": [{
                "key": "Content-Type",
                "value": "text/css; charset=utf-8"
            }]
        },
        {
            "source": "/script.js",
            "headers": [{
                "key": "Content-Type",
                "value": "application/javascript"
            }]
        }
    ]
}